5riverstruckinginc.ca {
    # GraphQL API
    reverse_proxy /graphql localhost:4001
    
    # REST API
    reverse_proxy /api/* localhost:4002
    
    # Frontend application
    reverse_proxy localhost:3000

    # Static file serving for uploads
    handle_path /uploads/jobs/* {
        root * D:\Projects\5rivers.app\5rivers.app.backend\uploads\jobs
        file_server
    }
    
    # Basic security
    header Strict-Transport-Security "max-age=31536000"
    header X-Content-Type-Options "nosniff"
    
    # Compression
    encode gzip
    
    # Logging
    log
}

www.5riverstruckinginc.ca {
    redir https://5riverstruckinginc.ca{uri} permanent
}