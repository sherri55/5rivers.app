# LLM Provider: gemini | groq | ollama | lmstudio (default: ollama)
LLM_PROVIDER=gemini

# Google Gemini API
GEMINI_API_KEY=AIzaSyAylmxKN1kZ0Q6R7T01_db5V7MskDBqRqg
GEMINI_MODEL=gemini-2.5-flash-lite

# Explicit context caching (system prompt + tool declarations).
# Cached prefix tokens are billed at ~25% of the normal rate.
# Set GEMINI_CACHE=false to disable; implicit prefix caching still applies.
# GEMINI_CACHE=true
# GEMINI_CACHE_TTL_S=600

# Image preprocessing (resize before sending to LLM).
# Larger images cost more tokens; phone-camera tickets read fine at 1568 px.
# LLM_IMAGE_MAX_EDGE=1568
# LLM_IMAGE_QUALITY=85

# Supervision mode — agent asks for confirmation before any write operation (default: true)
# Set to false once you are confident in the agent's behaviour
SUPERVISION_MODE=true

# Groq cloud API (free tier — https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama LLM (running on a separate machine)
OLLAMA_HOST=http://192.168.68.63:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_NUM_CTX=8192


# LM Studio / any local OpenAI-compatible server
# Tool-calling model — nvidia/nemotron-3-nano-4b (text only, function calling)
LMSTUDIO_HOST=http://localhost:1234
LMSTUDIO_TOOL_MODEL=nvidia/nemotron-3-nano-4b

# Vision / OCR model — google/gemma-4-e4b (image reading, no tool calling)
LMSTUDIO_VISION_HOST=http://localhost:1234
LMSTUDIO_VISION_MODEL=google/gemma-4-e4b


# 5Rivers Backend API
FIVE_RIVERS_API_URL=http://localhost:4000/api
FIVE_RIVERS_TOKEN=ddabeba8c514e390ad85f25288cf6cf08b76d94b2ec5dc2c6e8ce30a9a72fb77

