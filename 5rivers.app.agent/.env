# LLM Provider: groq | ollama | lmstudio (default: ollama)
LLM_PROVIDER=lmstudio

# Supervision mode — agent asks for confirmation before any write operation (default: true)
# Set to false once you are confident in the agent's behaviour
SUPERVISION_MODE=true

# Groq cloud API (free tier — https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama LLM (running on a separate machine)
OLLAMA_HOST=http://192.168.68.63:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_NUM_CTX=8192


# LM Studio / any local OpenAI-compatible server
# Tool-calling model — nvidia/nemotron-3-nano-4b (text only, function calling)
LMSTUDIO_HOST=http://localhost:1234
LMSTUDIO_TOOL_MODEL=nvidia/nemotron-3-nano-4b

# Vision / OCR model — google/gemma-4-e4b (image reading, no tool calling)
LMSTUDIO_VISION_HOST=http://localhost:1234
LMSTUDIO_VISION_MODEL=google/gemma-4-e4b


# 5Rivers Backend API
FIVE_RIVERS_API_URL=http://localhost:4000/api
FIVE_RIVERS_TOKEN=your-jwt-token-here

FIVE_RIVERS_EMAIL=info@5riverstruckinginc.ca
FIVE_RIVERS_PASSWORD=Demo123!
FIVE_RIVERS_ORG_SLUG=demo


# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Auth map file path (default: ./auth-map.json)
# AUTH_MAP_PATH=./auth-map.json
