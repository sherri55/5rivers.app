# LLM Provider: groq | ollama (default: ollama)
LLM_PROVIDER=ollama

# Groq cloud API (free tier — https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama LLM (running on a separate machine)
OLLAMA_HOST=http://192.168.68.63:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_NUM_CTX=8192

# 5Rivers Backend API
FIVE_RIVERS_API_URL=http://localhost:4000/api
FIVE_RIVERS_TOKEN=your-jwt-token-here

FIVE_RIVERS_EMAIL=info@5riverstruckinginc.ca
FIVE_RIVERS_PASSWORD=Demo123!
FIVE_RIVERS_ORG_SLUG=demo


# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Auth map file path (default: ./auth-map.json)
# AUTH_MAP_PATH=./auth-map.json
