# Backend API (required for auth + GraphQL)
# Start the backend first (e.g. cd 5rivers.app.backend && npm run dev). Restart this app after changing these.
VITE_API_URL=http://localhost:4001
VITE_GRAPHQL_ENDPOINT=http://localhost:4001/graphql
VITE_AUTH_LOGIN_ENDPOINT=http://localhost:4001/api/auth/login
VITE_UPLOAD_URL=http://localhost:4001/api/upload

# Optional: Gemini for AI Assistant
GEMINI_API_KEY=
