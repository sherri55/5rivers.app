{
  "name": "5rivers.server",
  "version": "1.0.0",
  "description": "5rivers API server – SQL Server, org-scoped, REST",
  "main": "dist/index.js",
  "scripts": {
    "build": "npx tsc",
    "start": "node dist/index.js",
    "dev": "npx ts-node-dev --respawn src/index.ts",
    "test": "npx jest --runInBand --forceExit",
    "test:watch": "npx jest --runInBand --watch",
    "test:db": "npx ts-node scripts/test-connection.ts",
    "db:schema": "npx ts-node scripts/apply-schema.ts",
    "db:migrate": "npx ts-node scripts/apply-migrations.ts",
    "db:seed": "npx ts-node scripts/seed-sample-user.ts",
    "db:assign-demo": "npx ts-node scripts/assign-migrated-data-to-demo-org.ts",
    "db:create-user": "npx ts-node scripts/create-user.ts",
    "migrate:neo4j-to-sql": "npx ts-node scripts/migrate-neo4j-to-sql.ts"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "neo4j-driver": "^5.15.0",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^10.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/mssql": "^9.1.5",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18"
  }
}
