PORT=4000
NODE_ENV=development
# SQL Server (required for app and for migrate:neo4j-to-sql)
DATABASE_URL=Server=localhost,1433;User Id=sa;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=True;Database=5rivers
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional: email that can log in to any org by slug (no membership required) and switch org via X-Organization-Id
# SUPER_ADMIN_EMAIL=admin@5rivers.app

# Neo4j (only for migrate:neo4j-to-sql)
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Optional: org for migrated data (default: 5rivers / 5rivers)
# MIGRATION_ORG_NAME=5rivers
# MIGRATION_ORG_SLUG=5rivers
